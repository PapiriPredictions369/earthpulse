# --- Upstash Redis (caching) ---
# Create a free Redis DB at https://console.upstash.com and copy the REST creds.
# Without these the app falls back to a per-instance in-memory cache (fine locally).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- NASA (solar flares via DONKI) ---
# Optional. "DEMO_KEY" works but is heavily rate-limited. Get a free key at
# https://api.nasa.gov to avoid throttling.
NASA_API_KEY=DEMO_KEY

# --- Schumann resonance (optional) ---
# There is no stable free public API for Schumann data. If you have a JSON
# endpoint returning { "frequency": number, "amplitude": number, "time": iso },
# set it here and the dashboard will show it live.
SCHUMANN_FEED_URL=

# --- AI Daily Briefing (optional) ---
# Anthropic API key. Without it, the briefing card shows a "set the key" note.
# Get one at https://console.anthropic.com (account needs credit).
ANTHROPIC_API_KEY=

# --- Telegram alerts (optional) ---
# Create a bot with @BotFather to get the token, then message your bot and get
# your chat id from https://api.telegram.org/bot<TOKEN>/getUpdates.
# Without these, the alert endpoint is a no-op that just reports candidates.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Cron protection (optional but recommended) ---
# If set, /api/cron/alerts requires Authorization: Bearer <CRON_SECRET>.
# Vercel Cron sends this automatically when the env var is present.
CRON_SECRET=
